generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  username       String   @unique
  password       String
  name           String
  className      String?
  role           String   @default("STUDENT")
  pointBalance   Float    @default(0)
  pyPointBalance Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  submissions              Submission[]
  assignments              Assignment[]              @relation("TeacherAssignments")
  pointRecords             StudentPointRecord[]      @relation("StudentPointRecords")
  operatedPointRecords     StudentPointRecord[]      @relation("OperatorPointRecords")
  pyPointRecords           StudentPyPointRecord[]    @relation("StudentPyPointRecords")
  operatedPyPointRecords   StudentPyPointRecord[]    @relation("OperatorPyPointRecords")
  questionBankItems        QuestionBankItem[]        @relation("TeacherQuestionBankItems")
  practicePapers           PracticePaper[]           @relation("TeacherPracticePapers")
  teachingPracticeSessions PracticeSession[]         @relation("TeacherPracticeSessions")
  studentPracticeSessions  PracticeSessionStudent[]  @relation("StudentPracticeSessions")
  practiceResponses        PracticeResponse[]        @relation("StudentPracticeResponses")
  challengeProgresses      ChallengeProgress[]       @relation("StudentChallengeProgresses")
  challengeSubmissions     ChallengeSubmission[]     @relation("StudentChallengeSubmissions")
  godotSessionBootstraps   GodotSessionBootstrap[]   @relation("UserGodotSessionBootstraps")
  classDefenseMonsterTypes ClassDefenseMonsterType[] @relation("TeacherClassDefenseMonsterTypes")
  pet                      StudentPet?
}

model LoginAttemptThrottle {
  id           String    @id @default(cuid())
  username     String    @unique
  failedCount  Int       @default(0)
  lockedUntil  DateTime?
  lastFailedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([lockedUntil])
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Assignment {
  id          String    @id @default(cuid())
  title       String
  description String
  defaultCode String?
  dueDate     DateTime?
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  teacherId   String
  teacher     User         @relation("TeacherAssignments", fields: [teacherId], references: [id])
  submissions Submission[]
}

model Submission {
  id          String    @id @default(cuid())
  code        String
  score       Int?
  feedback    String?
  submittedAt DateTime  @default(now())
  reviewedAt  DateTime?

  studentId    String
  student      User       @relation(fields: [studentId], references: [id])
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id])

  @@unique([studentId, assignmentId])
}

model StudentPointRecord {
  id              String   @id @default(cuid())
  studentId       String
  student         User     @relation("StudentPointRecords", fields: [studentId], references: [id], onDelete: Cascade)
  studentUsername String
  operatorId      String?
  operator        User?    @relation("OperatorPointRecords", fields: [operatorId], references: [id], onDelete: SetNull)
  operatorLabel   String?
  delta           Float
  reason          String
  occurredAt      DateTime
  source          String   @default("WEB")
  createdAt       DateTime @default(now())

  @@index([studentId, occurredAt])
  @@index([occurredAt])
}

model StudentPyPointRecord {
  id              String   @id @default(cuid())
  studentId       String
  student         User     @relation("StudentPyPointRecords", fields: [studentId], references: [id], onDelete: Cascade)
  studentUsername String
  operatorId      String?
  operator        User?    @relation("OperatorPyPointRecords", fields: [operatorId], references: [id], onDelete: SetNull)
  operatorLabel   String?
  delta           Int
  balanceBefore   Int
  balanceAfter    Int
  reason          String
  occurredAt      DateTime
  source          String   @default("WEB")
  clientRequestId String?
  createdAt       DateTime @default(now())

  @@unique([studentId, clientRequestId])
  @@index([studentId, occurredAt])
  @@index([occurredAt])
  @@index([source])
}

model StudentPet {
  id         String   @id @default(cuid())
  studentId  String   @unique
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  speciesKey String
  nickname   String?
  level      Int      @default(1)
  exp        Int      @default(0)
  currentHp  Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  equipmentSlots StudentPetEquipmentSlot[]
  skillSlots     StudentPetSkillSlot[]
  inventorySlots StudentPetInventorySlot[]
  expRecords     StudentPetExpRecord[]

  @@index([speciesKey])
}

model StudentPetEquipmentSlot {
  id            String     @id @default(cuid())
  petId         String
  pet           StudentPet @relation(fields: [petId], references: [id], onDelete: Cascade)
  slotIndex     Int
  equipmentKey  String?
  equipmentName String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([petId, slotIndex])
}

model StudentPetSkillSlot {
  id        String     @id @default(cuid())
  petId     String
  pet       StudentPet @relation(fields: [petId], references: [id], onDelete: Cascade)
  slotIndex Int
  skillKey  String?
  skillName String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([petId, slotIndex])
}

model StudentPetInventorySlot {
  id        String     @id @default(cuid())
  petId     String
  pet       StudentPet @relation(fields: [petId], references: [id], onDelete: Cascade)
  slotIndex Int
  itemKey   String?
  itemName  String?
  quantity  Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([petId, slotIndex])
}

model StudentPetExpRecord {
  id          String     @id @default(cuid())
  petId       String
  pet         StudentPet @relation(fields: [petId], references: [id], onDelete: Cascade)
  expDelta    Int
  pointDelta  Float?
  reason      String
  source      String     @default("POINT")
  levelBefore Int
  levelAfter  Int
  expBefore   Int
  expAfter    Int
  occurredAt  DateTime
  createdAt   DateTime   @default(now())

  @@index([petId, occurredAt])
}

model QuestionBankItem {
  id        String   @id @default(cuid())
  content   String
  type      String
  score     Int
  optionA   String?
  optionB   String?
  optionC   String?
  optionD   String?
  answer    String
  scope     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacherId String
  teacher   User   @relation("TeacherQuestionBankItems", fields: [teacherId], references: [id], onDelete: Cascade)

  paperQuestions PaperQuestion[]

  @@index([teacherId, type])
  @@index([teacherId, scope])
}

model PracticePaper {
  id          String   @id @default(cuid())
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teacherId String
  teacher   User   @relation("TeacherPracticePapers", fields: [teacherId], references: [id], onDelete: Cascade)

  questions PaperQuestion[]
  sessions  PracticeSession[]

  @@index([teacherId, createdAt])
}

model PaperQuestion {
  id         String   @id @default(cuid())
  orderIndex Int
  content    String
  type       String
  score      Int
  optionA    String?
  optionB    String?
  optionC    String?
  optionD    String?
  answer     String
  scope      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  paperId        String
  paper          PracticePaper     @relation(fields: [paperId], references: [id], onDelete: Cascade)
  questionBankId String?
  questionBank   QuestionBankItem? @relation(fields: [questionBankId], references: [id], onDelete: SetNull)

  responses PracticeResponse[]

  @@unique([paperId, orderIndex])
  @@index([paperId])
}

model PracticeSession {
  id                   String    @id @default(cuid())
  mode                 String
  status               String    @default("PENDING")
  className            String
  durationMinutes      Int?
  currentQuestionIndex Int       @default(0)
  startedAt            DateTime?
  questionStartedAt    DateTime?
  endedAt              DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  paperId   String
  paper     PracticePaper @relation(fields: [paperId], references: [id], onDelete: Cascade)
  teacherId String
  teacher   User          @relation("TeacherPracticeSessions", fields: [teacherId], references: [id], onDelete: Cascade)

  students  PracticeSessionStudent[]
  responses PracticeResponse[]

  @@index([teacherId, createdAt])
  @@index([className, status])
}

model PracticeSessionStudent {
  id                String    @id @default(cuid())
  status            String    @default("PENDING")
  questionOrder     String?
  optionOrder       String?
  startedAt         DateTime?
  submittedAt       DateTime?
  rawScore          Int?
  finalScore        Float?
  bonusMultiplier   Float?
  awardedPointDelta Float?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  sessionId String
  session   PracticeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentId String
  student   User            @relation("StudentPracticeSessions", fields: [studentId], references: [id], onDelete: Cascade)

  responses PracticeResponse[]

  @@unique([sessionId, studentId])
  @@index([studentId, createdAt])
}

model PracticeResponse {
  id                String    @id @default(cuid())
  answer            String
  isCorrect         Boolean?
  awardedScore      Int?
  awardedPointDelta Float?
  settledAt         DateTime?
  submittedAt       DateTime  @default(now())
  createdAt         DateTime  @default(now())

  sessionId        String
  session          PracticeSession        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentSessionId String
  studentSession   PracticeSessionStudent @relation(fields: [studentSessionId], references: [id], onDelete: Cascade)
  studentId        String
  student          User                   @relation("StudentPracticeResponses", fields: [studentId], references: [id], onDelete: Cascade)
  paperQuestionId  String
  paperQuestion    PaperQuestion          @relation(fields: [paperQuestionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId, paperQuestionId])
  @@index([paperQuestionId, submittedAt])
}

model ClassDefenseSession {
  id            String    @id @default(cuid())
  teacherId     String
  className     String
  paperId       String?
  status        String    @default("PENDING")
  classHp       Int
  maxClassHp    Int
  reviveSeconds Int       @default(30)
  configJson    String
  stateVersion  Int       @default(0)
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  participants ClassDefenseParticipant[]
  monsters     ClassDefenseMonster[]
  combats      ClassDefenseCombat[]
  answers      ClassDefenseAnswer[]
  events       ClassDefenseEvent[]

  @@index([teacherId, createdAt])
  @@index([className, status])
}

model ClassDefenseMonsterType {
  id         String   @id @default(cuid())
  teacherId  String
  teacher    User     @relation("TeacherClassDefenseMonsterTypes", fields: [teacherId], references: [id], onDelete: Cascade)
  name       String
  baseHp     Int
  baseAttack Int
  baseSpeed  Float
  imagePath  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([teacherId, createdAt])
}

model ClassDefenseParticipant {
  id          String              @id @default(cuid())
  sessionId   String
  session     ClassDefenseSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentId   String
  directionId String?
  status      String              @default("ALIVE")
  hp          Int
  maxHp       Int
  reviveAt    DateTime?
  connectedAt DateTime?
  lastSeenAt  DateTime?
  joinedAt    DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([sessionId, studentId])
  @@index([sessionId, directionId])
  @@index([sessionId, status])
  @@index([studentId, joinedAt])
}

model ClassDefenseMonster {
  id                String              @id @default(cuid())
  sessionId         String
  session           ClassDefenseSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  directionId       String              @default("east")
  waveIndex         Int
  laneIndex         Int                 @default(0)
  monsterKey        String
  monsterName       String?
  monsterLevel      Int                 @default(1)
  imagePath         String?
  status            String              @default("WALKING")
  hp                Int
  maxHp             Int
  attack            Int
  speed             Float
  routeProgress     Float               @default(0)
  lockedByStudentId String?
  lockExpiresAt     DateTime?
  reachedAt         DateTime?
  killedAt          DateTime?
  spawnedAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  combats ClassDefenseCombat[]
  answers ClassDefenseAnswer[]

  @@index([sessionId, status])
  @@index([sessionId, directionId, status])
  @@index([sessionId, lockedByStudentId])
}

model ClassDefenseCombat {
  id              String              @id @default(cuid())
  sessionId       String
  session         ClassDefenseSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  monsterId       String
  monster         ClassDefenseMonster @relation(fields: [monsterId], references: [id], onDelete: Cascade)
  studentId       String
  paperQuestionId String
  status          String              @default("ACTIVE")
  startedAt       DateTime            @default(now())
  expiresAt       DateTime?
  endedAt         DateTime?
  isCorrect       Boolean?
  damageToMonster Int?
  damageToStudent Int?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  answers ClassDefenseAnswer[]

  @@index([sessionId, studentId, status])
  @@index([monsterId, status])
}

model ClassDefenseAnswer {
  id              String              @id @default(cuid())
  combatId        String
  combat          ClassDefenseCombat  @relation(fields: [combatId], references: [id], onDelete: Cascade)
  sessionId       String
  session         ClassDefenseSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentId       String
  monsterId       String
  monster         ClassDefenseMonster @relation(fields: [monsterId], references: [id], onDelete: Cascade)
  roundIndex      Int                 @default(1)
  paperQuestionId String
  answer          String
  isCorrect       Boolean
  submittedAt     DateTime            @default(now())

  @@index([combatId, roundIndex])
  @@index([sessionId, studentId, submittedAt])
  @@index([sessionId, monsterId])
}

model ClassDefenseEvent {
  id           String              @id @default(cuid())
  sessionId    String
  session      ClassDefenseSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type         String
  payload      String
  stateVersion Int
  createdAt    DateTime            @default(now())

  @@index([sessionId, stateVersion])
  @@index([sessionId, createdAt])
}

model ChallengeChapterUnlock {
  id         String   @id @default(cuid())
  className  String
  chapterKey String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([className, chapterKey])
  @@index([className])
}

model ChallengeLevelUnlock {
  id         String   @id @default(cuid())
  className  String
  chapterKey String
  levelKey   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([className, chapterKey, levelKey])
  @@index([className, chapterKey])
}

model ChallengeProgress {
  id                 String    @id @default(cuid())
  status             String    @default("IN_PROGRESS")
  attemptCount       Int       @default(0)
  latestCode         String?
  latestJudgeMessage String?
  latestStdout       String?
  latestStderr       String?
  latestSubmittedAt  DateTime?
  firstPassedAt      DateTime?
  passedAt           DateTime?
  awardedPoints      Float     @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  studentId  String
  student    User   @relation("StudentChallengeProgresses", fields: [studentId], references: [id], onDelete: Cascade)
  chapterKey String
  levelKey   String

  @@unique([studentId, chapterKey, levelKey])
  @@index([studentId, updatedAt])
  @@index([chapterKey, levelKey])
}

model ChallengeSubmission {
  id            String   @id @default(cuid())
  code          String
  isPassed      Boolean
  judgeMessage  String
  stdout        String?
  stderr        String?
  pointsAwarded Float    @default(0)
  submittedAt   DateTime @default(now())
  createdAt     DateTime @default(now())

  studentId  String
  student    User   @relation("StudentChallengeSubmissions", fields: [studentId], references: [id], onDelete: Cascade)
  chapterKey String
  levelKey   String

  @@index([studentId, submittedAt])
  @@index([chapterKey, levelKey, submittedAt])
}

model ChallengeSubmitCooldown {
  studentId     String   @id
  nextAllowedAt DateTime
  updatedAt     DateTime @updatedAt
}

model GodotSessionBootstrap {
  id         String    @id @default(cuid())
  code       String    @unique
  clientType String    @default("GODOT")
  targetPath String
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  userId String
  user   User   @relation("UserGodotSessionBootstraps", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}
